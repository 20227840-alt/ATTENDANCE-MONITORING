@page
@model finalsproject.Pages.SignupModel
@{
    ViewData["Title"] = "Sign Up";
}

<div style="max-width:400px; margin:80px auto; padding:30px; border:1px solid #ddd; border-radius:10px;">
    <h2 style="text-align:center; margin-bottom:24px;">Create Account</h2>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <p style="color:red; text-align:center;">@Model.ErrorMessage</p>
    }

    <form method="post">
        <div style="margin-bottom:16px;">
            <label asp-for="Input.Email">Email</label>
            <input asp-for="Input.Email" type="email" class="form-control" placeholder="you@example.com" />
            <span asp-validation-for="Input.Email" style="color:red;"></span>
        </div>

        <div style="margin-bottom:16px;">
            <label asp-for="Input.Password">Password</label>
            <input asp-for="Input.Password" type="password" class="form-control" placeholder="Min. 8 characters" />
            <span asp-validation-for="Input.Password" style="color:red;"></span>
        </div>

        <div style="margin-bottom:16px;">
            <label asp-for="Input.ConfirmPassword">Confirm Password</label>
            <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="••••••••" />
            <span asp-validation-for="Input.ConfirmPassword" style="color:red;"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100">Create Account</button>
    </form>

    <p style="text-align:center; margin-top:16px;">
        Already have an account? <a asp-page="/Login">Sign in</a>
    </p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
